# ── PostgreSQL (Docker) ─────────────────────────────────────────────
POSTGRES_USER=sportbar
POSTGRES_PASSWORD=sportbar_dev
POSTGRES_DB=sportbar
POSTGRES_PORT=5432

# Cadena de conexion usada por Prisma / NestJS
DATABASE_URL="postgresql://sportbar:sportbar_dev@localhost:5432/sportbar?schema=public"

# ── Backend API ─────────────────────────────────────────────────────
API_PORT=3001
JWT_SECRET=cambiar_en_produccion
JWT_EXPIRES_IN=7d

# ── Frontend ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Pasarela de pagos: Wompi (Colombia) ─────────────────────────────
# Obtener en https://comercios.wompi.co (modo sandbox primero)
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxxxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxxxxx
WOMPI_BASE_URL=https://sandbox.wompi.co/v1

# ── Anticipo por defecto (porcentaje de abono) ──────────────────────
DEFAULT_DEPOSIT_PERCENT=50

# ── n8n (automatizaciones) ──────────────────────────────────────────
# Webhook que la API llama al confirmarse una reserva
N8N_WEBHOOK_RESERVA_CONFIRMADA=https://tu-n8n/webhook/reserva-confirmada
